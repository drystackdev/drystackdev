{
  "name": "drystack",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*",
    "ai-proxy"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "bun run --filter '@drystack/core' build && bun run --filter '@drystack/astro' build",
    "dev": "astro dev",
    "prebuild": "bun run --filter '@drystack/core' build && bun run --filter '@drystack/astro' build",
    "build": "astro build",
    "preview": "wrangler dev",
    "astro": "astro",
    "dev:b": "bun run dev --background",
    "dev:s": "bun run dev stop",
    "publish:packages": "bash scripts/publish.sh"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/react": "^6.0.1",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@drystack/astro": "workspace:*",
    "@drystack/core": "workspace:*",
    "astro": "^7.0.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "mkdist": "^2.4.1",
    "wrangler": "^4.110.0"
  }
}
