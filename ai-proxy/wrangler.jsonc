{
  "name": "drystack-ai-proxy",
  "main": "src/worker.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "ratelimits": [
    {
      "name": "AI_PROXY_RL",
      "namespace_id": "1",
      "simple": { "limit": 20, "period": 60 }
    }
  ],
  "vars": {
    "ALLOWED_ORIGINS": ""
  }
}
