---
import BlogListing from "../../components/BlogListing.astro";
import { getSeoKnowledgePosts } from "../../data/blog";
import { dry } from "@drystack/astro/dry";
import config from "../../../drystack.config";

const [posts, page] = await Promise.all([
  getSeoKnowledgePosts(),
  dry(config).singleton.seoKnowledgeListing,
]);
---

<BlogListing
  posts={posts}
  basePath="/blog-kien-thuc"
  metaTitle={page.metaTitle as string}
  metaDescription={page.metaDescription as string}
  ogImage={(page.ogImage as string) || undefined}
  eyebrow={page.eyebrow as string}
  eyebrowItemProps={page.item("eyebrow")}
  heading={page.heading as string}
  headingItemProps={page.item("heading")}
  lede={page.lede as string}
  ledeItemProps={page.item("lede")}
/>
