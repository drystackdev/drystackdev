---
import BlogPostDetail from "../../components/BlogPostDetail.astro";
import { getBlogPosts } from "../../data/blog";
import { dry } from "../../lib/dry";

// Every route in this site is SSR (astro.config.mjs's `output: "server"`),
// so there's no getStaticPaths() here - Astro.params.slug resolves straight
// off the incoming request, and content read from R2 is always current, no
// rebuild needed to see a save. .entry(), not .all().find() - reading (and
// parsing body.html for) every post just to find one slug would be wasted
// work on every single request.
const entry = await dry.collection("blog").entry(Astro.params.slug!);
if (!entry || !entry.publish) {
	return Astro.redirect("/blog");
}

// `related` only needs lightweight metadata (title/excerpt/cover/slug), not
// bind()/view() - getBlogPosts() already shapes that cheaply and is sorted
// by date, which entry.bind()'s shape doesn't carry.
const posts = await getBlogPosts();
const related = posts.filter((p) => p.slug !== entry.slug).slice(0, 3);
---

<BlogPostDetail
	entry={entry}
	related={related}
	basePath="/blog"
	eyebrowLabel="Bài viết"
/>
