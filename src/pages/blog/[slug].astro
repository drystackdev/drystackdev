---
import Layout from "@/layouts/main.astro"
import Nav from "@/components/Nav"
import Footer from "@/components/Footer"
import FloatContact from "@/components/FloatContact"
import BlogToc from "@/components/BlogToc"
import { Badge } from "@/components/ui/badge"
import { POSTS, relatedPosts, formatDateVi, slugifyHeading, type Post } from "@/lib/posts"

export function getStaticPaths() {
  return POSTS.map((p) => ({ params: { slug: p.slug }, props: { post: p } }))
}

const { post } = Astro.props as { post: Post }
const related = relatedPosts(post, 3)

const tocItems = post.sections.map((s) => ({ id: slugifyHeading(s.heading), heading: s.heading }))

const reveal = "opacity:0;transform:translateY(48px) scale(0.95);filter:blur(8px);will-change:transform,opacity,filter;"
---

<Layout title={`${post.title} — DryStack Blog`} description={post.excerpt}>
  <Nav client:load />

  <article
    id="blog-detail"
    style="scroll-margin-top:100px;position:relative;z-index:10;background:#faf5ec;color:#1a1206;padding:clamp(110px,12vw,150px) clamp(20px,5vw,40px) 0;"
  >
    <div style="max-width:1020px;margin:0 auto;position:relative;display:flex;gap:48px;">
      <div style="flex:1 1 auto;min-width:0;max-width:760px;">
        <a
          href="/blog"
          data-fx="reveal"
          data-from="up"
          style={`${reveal}display:inline-flex;align-items:center;gap:8px;font-size:13px;font-weight:600;color:rgba(26,18,6,0.55);text-decoration:none;margin-bottom:28px;`}
        >
          <iconify-icon icon="solar:arrow-left-linear" style="font-size:16px;"></iconify-icon>
          Tất cả bài viết
        </a>

        <div data-fx="reveal" data-from="up" style={`${reveal}margin-bottom:24px;`}>
          <Badge className="ds-chip-cat-light" style={{ marginBottom: "18px" }}>{post.cat}</Badge>
          <h1 style="font-family:var(--font-heading);font-size:clamp(28px,4vw,46px);font-weight:800;letter-spacing:-1.2px;line-height:1.18;margin-bottom:20px;color:#1a1206;">
            {post.title}
          </h1>

          {/* Tác giả + ngày đăng — click tên tác giả để lọc các bài cùng tác giả trên /blog */}
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
            <div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#ffd24a,#ff8a3d);display:flex;align-items:center;justify-content:center;font-family:var(--font-heading);font-weight:800;font-size:15px;color:#1a1206;flex-shrink:0;">
              {post.author.name.charAt(0)}
            </div>
            <div>
              <a
                href={`/blog?author=${encodeURIComponent(post.author.name)}`}
                style="font-size:14px;font-weight:700;color:#1a1206;text-decoration:none;"
              >
                {post.author.name}
              </a>
              <div style="font-size:12px;color:rgba(26,18,6,0.45);">{post.author.role}</div>
            </div>
            <div style="margin-left:auto;display:flex;align-items:center;gap:8px;font-size:13px;color:rgba(26,18,6,0.45);">
              <iconify-icon icon="solar:calendar-linear" style="font-size:15px;"></iconify-icon>
              <span>{formatDateVi(post.date)}</span>
              <span>·</span>
              <iconify-icon icon="solar:clock-circle-linear" style="font-size:15px;"></iconify-icon>
              <span>{post.readTime}</span>
            </div>
          </div>

          {/* Từ khoá — click để lọc bài viết theo từ khoá trên /blog */}
          <div style="display:flex;flex-wrap:wrap;gap:7px;">
            {post.tags.map((tag) => (
              <a href={`/blog?tag=${encodeURIComponent(tag)}`} class="ds-tag-chip" style="text-decoration:none;display:inline-block;">
                #{tag}
              </a>
            ))}
          </div>
        </div>

        {/* Tóm tắt */}
        <div
          data-fx="reveal"
          data-from="up"
          style={`${reveal}background:#fff;border-left:3px solid #ffab2e;border-radius:0 14px 14px 0;padding:18px 22px;margin-bottom:36px;box-shadow:0 10px 30px rgba(26,18,6,0.05);`}
        >
          <p style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(26,18,6,0.4);margin-bottom:8px;">
            Tóm tắt
          </p>
          <p style="font-size:15px;color:rgba(26,18,6,0.7);line-height:1.7;">{post.excerpt}</p>
        </div>

        <div
          data-fx="reveal"
          data-from="up"
          style={`${reveal}aspect-ratio:16/9;border-radius:22px;background:#fff;border:1px solid rgba(26,18,6,0.07);box-shadow:0 16px 44px rgba(26,18,6,0.07);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;margin-bottom:44px;`}
        >
          <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(26,18,6,0.05) 1px, transparent 1px);background-size:22px 22px;"></div>
          <iconify-icon icon={post.icon} style="font-size:110px;color:rgba(255,140,50,0.5);position:relative;"></iconify-icon>
        </div>

        <div
          data-fx="reveal"
          data-from="up"
          style={`${reveal}padding-bottom:60px;border-bottom:1px solid rgba(26,18,6,0.08);margin-bottom:60px;`}
        >
          {post.sections.map((section, si) => (
            <div style={si > 0 ? "margin-top:34px;" : ""}>
              <h2
                id={slugifyHeading(section.heading)}
                style="scroll-margin-top:110px;font-family:var(--font-heading);font-size:22px;font-weight:800;letter-spacing:-0.4px;color:#1a1206;margin-bottom:16px;"
              >
                {section.heading}
              </h2>
              {section.paragraphs.map((paragraph, pi) => (
                <p
                  style={`font-size:${si === 0 && pi === 0 ? 18 : 16}px;font-weight:${si === 0 && pi === 0 ? 600 : 400};color:${si === 0 && pi === 0 ? "#1a1206" : "rgba(26,18,6,0.68)"};line-height:1.85;margin-bottom:18px;`}
                >
                  {paragraph}
                </p>
              ))}
            </div>
          ))}
        </div>
      </div>

      <aside style="position:relative;">
        <BlogToc client:load items={tocItems} />
      </aside>
    </div>
  </article>

  {related.length > 0 && (
    <section style="position:relative;z-index:10;background:#faf5ec;color:#1a1206;padding:0 clamp(20px,5vw,40px) clamp(100px,10vw,130px);overflow:hidden;">
      <div style="max-width:1100px;margin:0 auto;position:relative;">
        <h2
          data-fx="reveal"
          data-from="up"
          style={`${reveal}font-family:var(--font-heading);font-size:clamp(22px,2.8vw,32px);font-weight:800;letter-spacing:-0.8px;margin-bottom:30px;`}
        >
          Bài viết liên quan
        </h2>
        <div style="display:flex;flex-wrap:wrap;gap:22px;">
          {related.map((p) => (
            <a
              href={`/blog/${p.slug}`}
              data-fx="reveal"
              data-from="up"
              class="ds-related-card"
              style={`${reveal}flex:1 1 290px;max-width:352px;background:#ffffff;border:1px solid rgba(26,18,6,0.07);border-radius:18px;overflow:hidden;cursor:pointer;display:block;color:inherit;text-decoration:none;box-shadow:0 16px 44px rgba(26,18,6,0.07);`}
            >
              <div style="height:140px;background:#faf5ec;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;">
                <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(26,18,6,0.05) 1px, transparent 1px);background-size:20px 20px;"></div>
                <iconify-icon icon={p.icon} style="font-size:40px;color:rgba(255,140,50,0.55);position:relative;"></iconify-icon>
              </div>
              <div style="padding:20px 22px;">
                <Badge className="ds-chip-cat-light">{p.cat}</Badge>
                <h3 style="font-family:var(--font-heading);font-size:15px;font-weight:700;line-height:1.4;margin:12px 0 0;letter-spacing:-0.2px;color:#1a1206;">
                  {p.title}
                </h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer />
  <FloatContact client:load />
</Layout>

<style>
  .ds-related-card {
    transition: transform 0.3s, border-color 0.3s;
  }
  .ds-related-card:hover {
    transform: translateY(-5px);
    border-color: rgba(255, 170, 60, 0.3);
  }
</style>
