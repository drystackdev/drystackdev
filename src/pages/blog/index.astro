---
import BlogListing from "../../components/BlogListing.astro";
import { dry } from "../../lib/dry";

// Unresolved (no resolveLinkedFiles) - a listing card only needs
// title/excerpt/cover, so this skips reading every post's body.html.
const [entries, page] = await Promise.all([
  dry.collection("blog").all(),
  dry.singleton("blogListing"),
]);
const posts = Object.values(entries).filter((p) => p.publish);
---

<BlogListing
  posts={posts}
  basePath="/blog"
  metaTitle={page.metaTitle as string}
  metaDescription={page.metaDescription as string}
  ogImage={(page.ogImage as string) || undefined}
  eyebrow={page.eyebrow as string}
  eyebrowItemProps={page.bind("eyebrow")}
  heading={page.heading as string}
  headingItemProps={page.bind("heading")}
  lede={page.lede as string}
  ledeItemProps={page.bind("lede")}
/>
