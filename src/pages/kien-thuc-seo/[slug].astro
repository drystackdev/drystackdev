---
import BlogPostDetail from "../../components/BlogPostDetail.astro";
import { getSeoKnowledgePosts } from "../../data/blog";

// Every route in this site is SSR (astro.config.mjs's `output: "server"`),
// so there's no getStaticPaths() here - Astro.params.slug resolves straight
// off the incoming request, and content read from R2 is always current, no
// rebuild needed to see a save.
const posts = await getSeoKnowledgePosts();
const post = posts.find((p) => p.slug === Astro.params.slug);
if (!post) {
	return Astro.redirect("/kien-thuc-seo");
}

const related = posts.filter((p) => p.slug !== post.slug).slice(0, 3);

// seoKnowledge isn't wired to VEI yet (MVP1 scope: only the `blog`
// collection - see plan). BlogPostDetail now expects a bindable dry entry,
// so hand it a plain (non-editable) stand-in with the same fields: bind()/
// view() no-op to `{}`, the same fallback dry.ts's own makeSpot already
// returns for a spot it can't resolve, so no `data-dry` attribute is
// emitted and nothing here is falsely presented as editable.
const entry = {
	...post,
	body: post.contentHtml,
	publish: true,
	bind: (() => ({})) as any,
	view: (() => ({})) as any,
};
---

<BlogPostDetail
	entry={entry}
	related={related}
	basePath="/kien-thuc-seo"
	eyebrowLabel="Kiến thức SEO"
/>
