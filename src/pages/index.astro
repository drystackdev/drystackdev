---
import Layout from "@/layouts/main.astro"
import Nav from "@/components/Nav"
import Hero from "@/components/Hero"
import Marquee from "@/components/Marquee"
import About from "@/components/About"
import Services from "@/components/Services"
import TechCloud from "@/components/TechCloud"
import Projects from "@/components/Projects"
import Team from "@/components/Team"
import Pricing from "@/components/Pricing"
import Testimonials from "@/components/Testimonials"
import Knowledge from "@/components/Knowledge"
import Blog from "@/components/Blog"
import Contact from "@/components/Contact"
import Footer from "@/components/Footer"
import FloatContact from "@/components/FloatContact"
import { formatDateVi } from "@/lib/posts"
import {
  getHero,
  getServices,
  getProjects,
  getPricing,
  getTestimonials,
  getTips,
  getPosts,
  getSiteSetting,
} from "@/lib/cms"

const site = Astro.site?.href.replace(/\/$/, "") ?? "https://drystack.dev"

// ── Đọc dữ liệu CMS ở server/build-time (KHÔNG gọi từ client) ──
// Mọi giá trị có thể là null khi CMS tắt → component tự dùng default tĩnh.
// Khi mở từ "Open preview" của Strapi (?preview=1) → fetch bản nháp (draft).
const isPreview = Astro.url.searchParams.get("preview") === "1"
const opts = isPreview ? { draft: true } : undefined
const [hero, services, projects, pricing, testimonials, tips, posts, setting] =
  await Promise.all([
    getHero(opts),
    getServices(opts),
    getProjects(opts),
    getPricing(opts),
    getTestimonials(opts),
    getTips(opts),
    getPosts(opts),
    getSiteSetting(opts),
  ])

// Blog preview ở trang chủ: 3 bài mới nhất, map về shape {icon,cat,title,excerpt,meta}.
const blogPreview = posts
  ? [...posts]
      .sort((a, b) => b.date.localeCompare(a.date))
      .slice(0, 3)
      .map((p) => ({
        icon: p.icon,
        cat: p.cat,
        title: p.title,
        excerpt: p.excerpt,
        meta: `${formatDateVi(p.date)} · ${p.readTime}`,
      }))
  : undefined

// Organization + WebSite cho trang chủ giúp Google hiểu thực thể thương hiệu
// và bật ô tìm kiếm sitelinks.
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "DryStack.dev",
    url: site,
    logo: `${site}/favicon.svg`,
    description:
      "Team freelance chuyên thiết kế website, logo, branding và SEO cho doanh nghiệp Việt.",
    areaServed: "VN",
    knowsAbout: ["Thiết kế website", "Logo", "Branding", "SEO", "Landing page"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "DryStack.dev",
    url: site,
    inLanguage: "vi-VN",
  },
]
---

<Layout
  title="DryStack.dev — Thiết kế website, logo & branding cho doanh nghiệp Việt"
  description="Team freelance DryStack thiết kế website, logo, branding và SEO chuẩn cho doanh nghiệp Việt. Tốc độ nhanh, chuẩn SEO, giá chỉ từ 2.000.000đ. Nhận tư vấn miễn phí."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  <Nav client:load ctaLabel={setting?.ctaLabel} />
  <div style="position:relative; height:130vh;">
    <Hero
      client:load
      badge={hero?.badge}
      headlinePre={hero?.headlinePre}
      typewriterTexts={hero?.typewriterTexts}
      description={hero?.description}
      ctaPrimary={hero?.ctaPrimary}
      ctaSecondary={hero?.ctaSecondary}
      stats={hero?.stats}
    />
  </div>
  <Marquee />
  <About
    client:load
    heading={setting?.aboutHeading}
    paragraphs={setting?.aboutParagraphs}
    points={setting?.aboutPoints}
  />
  <Services services={services ?? undefined} />
  <TechCloud client:load />
  <Projects projects={projects ?? undefined} />
  <Team client:load />
  <Pricing plans={pricing ?? undefined} />
  <Testimonials client:load reviews={testimonials ?? undefined} />
  <Knowledge tips={tips ?? undefined} />
  <Blog posts={blogPreview} />
  <Contact client:load infos={setting?.contactInfos ?? undefined} />
  <Footer
    description={setting?.footerDesc}
    serviceLinks={setting?.serviceLinks}
    companyLinks={setting?.companyLinks}
    socials={setting?.socials}
    copyright={setting?.copyright}
    credit={setting?.credit}
  />
  <FloatContact client:load />
</Layout>
