---
// Infinite horizontal marquee of service keywords.
const words = [
  "THIẾT KẾ WEBSITE",
  "THIẾT KẾ LOGO",
  "BRANDING",
  "VIẾT BÀI SEO",
  "UI/UX DESIGN",
  "AUTOMATION TESTING",
]
// Duplicated once so the -50% translate loops seamlessly.
const items = [...words, ...words]
---

<div
  style="overflow:hidden; padding:18px 0; border-top:1px solid rgba(255,200,90,0.08); border-bottom:1px solid rgba(255,200,90,0.08); background:rgba(255,255,255,0.014); position:relative; z-index:1;"
>
  <div style="display:flex; gap:46px; width:max-content; animation:marquee 26s linear infinite; align-items:center;">
    {
      items.map((w, i) => (
        <>
          <span style="font-family:var(--font-heading); font-size:12px; font-weight:700; letter-spacing:3px; text-transform:uppercase; color:rgba(245,236,224,0.3); white-space:nowrap;">
            {w}
          </span>
          <iconify-icon icon="solar:star-bold" style={`color:${i % 2 === 0 ? "#ffae3d" : "#ff8a3d"}; font-size:13px;`} />
        </>
      ))
    }
  </div>
</div>
