---
import { dry as createDry } from "@drystack/astro/dry";
import config from "../../drystack.config";
import Image from "astro/components/Image.astro";

const dry = await createDry(config).singleton.demo;
---

<main>
  <h1 {...dry.item("text")}>{dry.text}</h1>
  {
    dry.image && (
      <Image
        width={200}
        height={200}
        alt="hình ảnh demo"
        src={dry.image}
        {...dry.item("image")}
      />
    )
  }

  <ul
    {...dry.item("array")}
    style="display: flex; flex-direction: column; gap: 1rem"
  >
    {dry.array.map((i, idx) => <li {...dry.item(`array.${idx}`)}>{i}</li>)}
  </ul>

  <div class="imglist" {...dry.item("arrayImg")}>
    {
      dry.arrayImg.map((img, idx) => (
        <Image
          width={200}
          height={200}
          alt="hình ảnh demo"
          src={img!}
          {...dry.item(`arrayImg.${idx}`)}
        />
      ))
    }
  </div>

  <div class="imglist" {...dry.item("arrayObject")}>
    {
      dry.arrayObject.map((obj, idx) => (
        <div
          style="display:flex; flex-direction: column; gap: 1rem"
          {...dry.item(`arrayObject.${idx}`)}
        >
          <h4 {...dry.item(`arrayObject.${idx}.name`)}>{obj.name}</h4>
          <Image
            width={200}
            height={200}
            alt="hình ảnh demo"
            src={obj.image!}
            {...dry.item(`arrayObject.${idx}.image`)}
          />
        </div>
      ))
    }
  </div>
</main>

<style>
  .imglist {
    display: flex;
    gap: 1rem;
    & > img {
      width: 200px;
      height: 200px;
      object-fit: cover;
    }
  }
  main {
    min-height: 70dvh;
    padding-top: 10rem;
    padding-bottom: 5rem;
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  img {
    object-fit: contain;
    width: 300px;
    height: auto;
  }
</style>
