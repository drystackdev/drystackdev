---
import { dry as createDry } from "@drystack/astro/dry";
import config from "../../drystack.config";
import { Image } from "astro:assets";

const dry = await createDry(config).singleton.demo;
---

<main>
  <h1 {...dry.item("text")}>{dry.text}</h1>
  <div {...dry.item("content")} set:html={dry.content}/>
  {
    dry.image && (
      <Image
        width={200}
        height={200}
        alt="hình ảnh demo"
        src={dry.image}
        {...dry.item("image")}
      />
    )
  }

  <a href={dry.file ?? undefined} hidden={!dry.file} {...dry.item("file")}>
    Tải tệp demo
  </a>

  <ul
    {...dry.item("array")}
    style="display: flex; flex-direction: column; gap: 1rem"
  >
    {dry.array.map((i, idx) => <li>
      <div {...dry.item(`array.${idx}`)} style="padding: 1rem;">{i}</div>
    </li>)}
  </ul>

  <div class="imglist" {...dry.item("arrayImg")}>
    {
      dry.arrayImg.map((img, idx) => (
        <Image
          width={200}
          height={200}
          alt="hình ảnh demo"
          src={img!}
          {...dry.item(`arrayImg.${idx}`)}
        />
      ))
    }
  </div>

  <div class="imglist" {...dry.item("arrayObject")}>
    {
      dry.arrayObject.map((obj, idx) => (
        <div
          style="display:flex; flex-direction: column; gap: 1rem"
        >
          <h4 {...dry.item(`arrayObject.${idx}.name`)}>{obj.name}</h4>
          <Image
            width={200}
            height={200}
            alt="hình ảnh demo"
            src={obj.image!}
            {...dry.item(`arrayObject.${idx}.image`)}
          />
          <a href={obj.file ?? '#'} {...dry.item(`arrayObject.${idx}.file`)}>
            Tải tệp
          </a>
        </div>
      ))
    }
  </div>

  {/* [field.Object] — standalone top-level fields.object, with a nested
      fields.array of text inside it (object > array). The container itself
      carries its own dry.item("info") mark so it gets a gear-button dialog
      (see Toolbar.tsx's ContainerFieldDialog), same as a top-level array. */}
  <div {...dry.item("info")} style="display:flex; flex-direction: column; gap: 1rem;">
    <h4 {...dry.item("info.label")}>{dry.info.label}</h4>
    {
      dry.info.thumb && (
        <Image
          width={200}
          height={200}
          alt="hình ảnh demo"
          src={dry.info.thumb}
          {...dry.item("info.thumb")}
        />
      )
    }
    <ul {...dry.item("info.links")} style="display: flex; flex-direction: column; gap: 0.5rem;">
      {dry.info.links.map((link, idx) => (
        <li>
          <div {...dry.item(`info.links.${idx}`)}>{link}</div>
        </li>
      ))}
    </ul>
  </div>

  {/* [field.ArrayObjectArray] — array > object > array. Unlike arrayObject
      above, each section wrapper *must* carry its own dry.item("sections.N")
      mark (not left unmarked) because it contains a further-nested container
      (its own "items" array) — see bind.ts's readContainerValue/
      paintContainerValue and plan/de-quy-object.md's authoring convention. */}
  <div {...dry.item("sections")} style="display:flex; flex-direction: column; gap: 1.5rem;">
    {dry.sections.map((section, i) => (
      <div
        style="display:flex; flex-direction: column; gap: 0.5rem; border: 1px solid #ccc; padding: 1rem;"
      >
        <h4 {...dry.item(`sections.${i}.title`)}>{section.title}</h4>
        <ul
          {...dry.item(`sections.${i}.items`)}
          style="display:flex; flex-direction: column; gap: 0.5rem;"
        >
          {section.items.map((item, j) => (
            <li>
              <div {...dry.item(`sections.${i}.items.${j}`)}>{item}</div>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</main>

<style>
  .imglist {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    & > img {
      width: 200px;
      height: 200px;
      object-fit: cover;
    }
  }
  main {
    min-height: 70dvh;
    padding-top: 10rem;
    padding-bottom: 5rem;
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  section h2 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.6;
  }
  img {
    object-fit: cover;
  }
  .empty-spot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 120px;
    min-height: 80px;
    border: 1px dashed color-mix(in srgb, currentColor 30%, transparent);
    border-radius: 0.5rem;
    font-size: 0.85rem;
    opacity: 0.5;
    padding: 0.5rem;
  }
  .empty-spot.avatar {
    min-width: 80px;
    min-height: 80px;
    border-radius: 999px;
  }
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
    & > li {
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      background: color-mix(in srgb, currentColor 8%, transparent);
      font-size: 0.9rem;
    }
  }
  .profile {
    display: flex;
    align-items: center;
    gap: 1rem;
    & img {
      width: 80px;
      height: 80px;
      border-radius: 999px;
    }
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    border-radius: 0.75rem;
    flex: 1 1 200px;
    & img {
      width: 64px;
      height: 64px;
    }
  }
</style>
