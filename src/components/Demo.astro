---
import { dry } from "../lib/dry";
import { Image } from "astro:assets";

const demo = await dry.singleton("demo");
---

<main>
  <h1 {...demo.bind("text")}>{demo.bind("text").value()}</h1>
  <div {...demo.bind("content")} set:html={demo.content} />

  {
    /* [demo.view] - a .view() readonly mirror of the same "text"/"content"
      fields bound above: same data-dry key, so it stays live-synced with
      whatever's typed into the editable spots above, but never becomes
      contentEditable/gets a ProseMirror mount itself (see dry.ts's .view(),
      bind.ts's isReadonlySpot, InlineContentEditors.tsx's readContentSpots). */
  }
  <section style="border: 1px dashed currentColor; opacity: 0.75; padding: 1rem; border-radius: 0.5rem;">
    <p style="font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.7;">
      Read-only mirror (dry.view)
    </p>
    <p {...demo.view("text")}>{demo.text}</p>
    <div {...demo.view("content")} set:html={demo.content} />
  </section>

  {
    demo.image && (
      <Image
        width={200}
        height={200}
        alt="hình ảnh demo"
        src={demo.image}
        {...demo.bind("image")}
      />
    )
  }

  <a href={demo.file ?? undefined} hidden={!demo.file} {...demo.bind("file")}>
    Tải tệp demo
  </a>

  <ul
    {...demo.bind("array")}
    style="display: flex; flex-direction: column; gap: 1rem"
  >
    {
      demo.array.map((i, idx) => (
        <li>
          <div {...demo.bind(`array.${idx}`)} style="padding: 1rem;">
            {i}
          </div>
        </li>
      ))
    }
  </ul>

  <div class="imglist" {...demo.bind("arrayImg")}>
    {
      demo.arrayImg.map(
        (img, idx) =>
          img && (
            <Image
              width={200}
              height={200}
              alt="hình ảnh demo"
              src={img}
              {...demo.bind(`arrayImg.${idx}`)}
            />
          ),
      )
    }
  </div>

  <div class="imglist" {...demo.bind("arrayObject")}>
    {
      demo.arrayObject.map((obj, idx) => (
        <div style="display:flex; flex-direction: column; gap: 1rem">
          <h4 {...demo.bind(`arrayObject.${idx}.name`)}>{obj.name}</h4>
          {obj.image && (
            <Image
              width={200}
              height={200}
              alt="hình ảnh demo"
              src={obj.image}
              {...demo.bind(`arrayObject.${idx}.image`)}
            />
          )}
          <a href={obj.file ?? "#"} {...demo.bind(`arrayObject.${idx}.file`)}>
            Tải tệp
          </a>
        </div>
      ))
    }
  </div>

  {
    /* [field.Object] - standalone top-level fields.object, with a nested
      fields.array of text inside it (object > array). The container itself
      carries its own demo.bind("info") mark so it gets a gear-button dialog
      (see Toolbar.tsx's ContainerFieldDialog), same as a top-level array. */
  }
  <div
    {...demo.bind("info")}
    style="display:flex; flex-direction: column; gap: 1rem;"
  >
    <h4 {...demo.bind("info.label")}>{demo.info.label}</h4>
    {
      demo.info.thumb && (
        <Image
          width={200}
          height={200}
          alt="hình ảnh demo"
          src={demo.info.thumb}
          {...demo.bind("info.thumb")}
        />
      )
    }
    <ul
      {...demo.bind("info.links")}
      style="display: flex; flex-direction: column; gap: 0.5rem;"
    >
      {
        demo.info.links.map((link, idx) => (
          <li>
            <div {...demo.bind(`info.links.${idx}`)}>{link}</div>
          </li>
        ))
      }
    </ul>
  </div>

  {
    /* [field.ArrayObjectArray] - array > object > array. Unlike arrayObject
      above, each section wrapper *must* carry its own demo.bind("sections.N")
      mark (not left unmarked) because it contains a further-nested container
      (its own "items" array) - see bind.ts's readContainerValue/
      paintContainerValue and plan/de-quy-object.md's authoring convention. */
  }
  <div
    {...demo.bind("sections")}
    style="display:flex; flex-direction: column; gap: 1.5rem;"
  >
    {
      demo.sections.map((section, i) => (
        <div style="display:flex; flex-direction: column; gap: 0.5rem; border: 1px solid #ccc; padding: 1rem;">
          <h4 {...demo.bind(`sections.${i}.title`)}>{section.title}</h4>
          <ul
            {...demo.bind(`sections.${i}.items`)}
            style="display:flex; flex-direction: column; gap: 0.5rem;"
          >
            {section.items.map((item, j) => (
              <li>
                <div {...demo.bind(`sections.${i}.items.${j}`)}>{item}</div>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</main>

<!-- Intentionally NOT is:global (unlike the other components): the block below
  has bare element selectors (main, section, img) that would leak site-wide.
  This is the internal /demo route only, so trimming its HTML doesn't matter. -->
<style>
  .imglist {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    & > img {
      width: 200px;
      height: 200px;
      object-fit: cover;
    }
  }
  main {
    min-height: 70dvh;
    padding-top: 10rem;
    padding-bottom: 5rem;
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  section h2 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.6;
  }
  img {
    object-fit: cover;
  }
  .empty-spot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 120px;
    min-height: 80px;
    border: 1px dashed color-mix(in srgb, currentColor 30%, transparent);
    border-radius: 0.5rem;
    font-size: 0.85rem;
    opacity: 0.5;
    padding: 0.5rem;
  }
  .empty-spot.avatar {
    min-width: 80px;
    min-height: 80px;
    border-radius: 999px;
  }
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
    & > li {
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      background: color-mix(in srgb, currentColor 8%, transparent);
      font-size: 0.9rem;
    }
  }
  .profile {
    display: flex;
    align-items: center;
    gap: 1rem;
    & img {
      width: 80px;
      height: 80px;
      border-radius: 999px;
    }
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    border: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    border-radius: 0.75rem;
    flex: 1 1 200px;
    & img {
      width: 64px;
      height: 64px;
    }
  }
</style>
