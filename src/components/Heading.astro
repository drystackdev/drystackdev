---
import type { DryItem } from "@drystack/astro/dry";

interface Props {
  // Trusted HTML from a `fields.content()` value (bold-only) - never raw user
  // input.
  html: string;
  // VEI mark for this spot, e.g. `page.item("heading")` - spread onto the
  // same element that carries `set:html` (see Demo.astro's content pattern).
  itemProps?: DryItem | {};
  // Extra class alongside "heading-rich", for callers that need their own
  // emphasis styling (e.g. brand.name's outline/gradient split) instead of
  // the default gradient-on-strong look.
  class?: string;
}

const { html, itemProps = {}, class: extraClass } = Astro.props;
---

<span
  class:list={["heading-rich", extraClass]}
  set:html={html}
  {...itemProps}
/>
