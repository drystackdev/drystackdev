---
const serviceLinks = [
  { href: "#services", label: "Thiết kế Website" },
  { href: "#services", label: "Thiết kế Logo" },
  { href: "#services", label: "Branding" },
  { href: "#services", label: "Viết bài SEO" },
]
const companyLinks = [
  { href: "#about", label: "Về chúng tôi" },
  { href: "#team", label: "Đội ngũ" },
  { href: "#projects", label: "Dự án" },
  { href: "#blog", label: "Blog" },
]
const socials = [
  { icon: "logos:facebook", label: "Facebook", href: "https://facebook.com/drystack" },
  { icon: "logos:tiktok-icon", label: "TikTok", href: "https://tiktok.com/@drystack" },
  { icon: "logos:telegram", label: "Telegram", href: "https://t.me/drystack" },
  { icon: "simple-icons:zalo", label: "Zalo", href: "https://zalo.me/0866442504" },
]
---

<footer
  style="position:relative; z-index:12; margin-top:-48px; border-radius:52px 52px 0 0; border-top:1px solid rgba(255,200,90,0.08); padding:90px clamp(20px,5vw,40px) 40px; background:#0a0703; box-shadow:0 -24px 60px rgba(0,0,0,0.5);"
>
  <div style="max-width:1100px; margin:0 auto;">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:44px; margin-bottom:52px;">
      <div style="min-width:220px;">
        <div style="display:flex; align-items:center; font-family:var(--font-heading); font-weight:800; font-size:20px; letter-spacing:-0.5px; margin-bottom:16px;">
          <div style="width:30px; height:30px; border-radius:8px; display:flex; align-items:center; justify-content:center; background:linear-gradient(#1a1206,#1a1206) padding-box, linear-gradient(135deg,#ffd24a,#ff8a3d) border-box; border:1.5px solid transparent; margin-right:10px;">
            <iconify-icon icon="solar:layers-bold-duotone" style="font-size:16px; color:#ffb13d;"></iconify-icon>
          </div>
          <span class="ds-grad-text">Dry</span>Stack<span style="color:rgba(245,236,224,0.4); font-weight:600;">.dev</span>
        </div>
        <p style="font-size:14px; color:rgba(245,236,224,0.42); line-height:1.75; max-width:260px; font-weight:300; margin-bottom:22px;">Team freelance chuyên thiết kế website &amp; branding cho doanh nghiệp Việt. Giá rẻ, chất lượng đỉnh.</p>
        <div style="display:flex; gap:10px;">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="ds-social"
                aria-label={s.label}
                style="width:38px; height:38px; background:rgba(255,200,90,0.06); border:1px solid rgba(255,200,90,0.12); border-radius:10px; display:flex; align-items:center; justify-content:center;"
              >
                <iconify-icon icon={s.icon} style="font-size:18px;" />
              </a>
            ))
          }
        </div>
      </div>
      <div>
        <div style="font-size:12px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(245,236,224,0.35); margin-bottom:18px;">DỊCH VỤ</div>
        <div style="display:flex; flex-direction:column; gap:12px;">
          {
            serviceLinks.map((l) => (
              <a href={l.href} class="ds-flink">
                {l.label}
              </a>
            ))
          }
        </div>
      </div>
      <div>
        <div style="font-size:12px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(245,236,224,0.35); margin-bottom:18px;">CÔNG TY</div>
        <div style="display:flex; flex-direction:column; gap:12px;">
          {
            companyLinks.map((l) => (
              <a href={l.href} class="ds-flink">
                {l.label}
              </a>
            ))
          }
        </div>
      </div>
      <div>
        <div style="font-size:12px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:rgba(245,236,224,0.35); margin-bottom:18px;">LIÊN HỆ</div>
        <div style="display:flex; flex-direction:column; gap:12px;">
          <a href="mailto:info@drystack.dev" class="ds-flink">info@drystack.dev</a>
          <a href="tel:0866442504" class="ds-flink">0866 442 504</a>
          <span style="font-size:14px; color:rgba(245,236,224,0.52); font-weight:300;">Toàn quốc, Việt Nam</span>
          <a href="#pricing" class="ds-link-gold" style="font-size:14px; font-weight:500; color:#ffce6a;">Xem bảng giá →</a>
        </div>
      </div>
    </div>
    <div style="border-top:1px solid rgba(255,200,90,0.07); padding-top:26px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
      <p style="font-size:13px; color:rgba(245,236,224,0.3); font-weight:300;">© 2024 DryStack. All rights reserved.</p>
      <p style="font-size:13px; color:rgba(245,236,224,0.3); font-weight:300;">Made by Thanh Khan in Việt Nam</p>
    </div>
  </div>
</footer>
