---
// About — light section with rotating accent, tilt card, and reveal text.
const points = [
  "Tư vấn miễn phí, báo giá trong 24h",
  "Giao sản phẩm đúng deadline cam kết",
  "Hỗ trợ sau bàn giao, bảo hành dài hạn",
]
---

<section
  id="about"
  style="scroll-margin-top:100px; position:relative; z-index:2; margin-top:-48px; background:#faf5ec; color:#1a1206; padding:clamp(80px,10vw,130px) clamp(20px,5vw,40px) clamp(80px,10vw,120px); overflow:hidden; box-shadow:0 -24px 60px rgba(0,0,0,0.35); border-radius:32px 32px 0 0;"
>
  <div
    data-fx="parallax"
    data-speed="0.45"
    style="position:absolute; top:30px; right:-30px; font-family:var(--font-heading); font-size:clamp(120px,18vw,210px); font-weight:800; color:rgba(26,18,6,0.035); letter-spacing:-10px; line-height:0.8; pointer-events:none; white-space:nowrap;"
  >
    ABOUT
  </div>
  <div style="max-width:1180px; margin:0 auto; position:relative;">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(310px,1fr)); gap:64px; align-items:center;">
      <div
        data-fx="reveal"
        data-from="right"
        style="opacity:0; transform:translateX(90px) scale(0.96); filter:blur(8px); will-change:transform,opacity,filter; position:relative;"
      >
        <div
          data-fx="rotate"
          data-rot="-10"
          style="position:absolute; top:-24px; left:-24px; width:120px; height:120px; border-radius:28px; background:linear-gradient(135deg,#ffd24a,#ff8a3d); opacity:0.85; z-index:0;"
        >
        </div>
        <div
          data-fx="tilt"
          style="position:relative; z-index:1; background:#ffffff; border-radius:26px; padding:clamp(36px,4vw,52px) clamp(30px,3.5vw,46px); box-shadow:0 30px 70px rgba(26,18,6,0.12); overflow:hidden; transform-origin:center center; will-change:transform;"
        >
          <div style="font-family:var(--font-heading); font-size:60px; font-weight:800; color:rgba(26,18,6,0.05); line-height:1; margin-bottom:22px; letter-spacing:-3px;">DRYSTACK</div>
          <div class="ds-grad-text-light" style="font-size:11px; font-weight:700; letter-spacing:3px; text-transform:uppercase; margin-bottom:10px;">✦ EST. 2022 · TOÀN QUỐC</div>
          <p style="font-size:15px; color:rgba(26,18,6,0.6); line-height:1.7; max-width:300px;">Team freelance tận tâm, chuyên xây dựng thương hiệu số cho doanh nghiệp Việt với giá phải chăng.</p>
          <div style="margin-top:34px; height:1px; background:linear-gradient(90deg, rgba(255,140,50,0.5), transparent);"></div>
          <div style="margin-top:20px; display:flex; align-items:center; gap:10px;">
            <div style="width:8px; height:8px; background:#ff8a3d; border-radius:50%; animation:blink 2.5s infinite;"></div>
            <span style="font-size:13px; color:rgba(26,18,6,0.5);">Đang nhận dự án mới</span>
          </div>
        </div>
      </div>
      <div
        data-fx="reveal"
        data-from="left"
        style="opacity:0; transform:translateX(-90px) scale(0.96); filter:blur(8px); will-change:transform,opacity,filter;"
      >
        <p class="ds-grad-text-light" style="font-size:11px; font-weight:700; letter-spacing:3px; text-transform:uppercase; margin-bottom:16px;">VỀ CHÚNG TÔI</p>
        <h2 style="font-family:var(--font-heading); font-size:clamp(30px,3.8vw,48px); font-weight:800; letter-spacing:-1.2px; line-height:1.15; margin-bottom:24px; color:#1a1206;">Thương hiệu mạnh<br />bắt đầu từ đây</h2>
        <p style="font-size:16px; color:rgba(26,18,6,0.62); line-height:1.82; margin-bottom:18px;">DryStack là team freelance chuyên thiết kế website và branding cho doanh nghiệp vừa và nhỏ trên toàn quốc. Mọi doanh nghiệp đều xứng đáng có thương hiệu đẳng cấp — dù ngân sách lớn hay nhỏ.</p>
        <p style="font-size:16px; color:rgba(26,18,6,0.62); line-height:1.82; margin-bottom:38px;">Với phương châm <strong style="color:#1a1206; font-weight:700;">"Giá rẻ, chất lượng đỉnh"</strong>, chúng tôi đã đồng hành cùng hơn 50 doanh nghiệp.</p>
        <div style="display:flex; flex-direction:column; gap:15px;">
          {
            points.map((p) => (
              <div style="display:flex; align-items:center; gap:12px;">
                <iconify-icon icon="solar:check-circle-bold" style="font-size:24px; color:#ff8a3d; flex-shrink:0;" />
                <span style="font-size:15px; color:rgba(26,18,6,0.75);">{p}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
