---
import TeamCarousel from "@/components/TeamCarousel"
---

<section
  id="team"
  style="scroll-margin-top:100px; position:relative; z-index:6; margin-top:-48px; border-radius:52px 52px 0 0; background:#faf5ec; color:#1a1206; padding:clamp(80px,10vw,130px) clamp(20px,5vw,40px) clamp(80px,10vw,120px); overflow:hidden; box-shadow:0 -24px 60px rgba(0,0,0,0.35);"
>
  <div
    data-fx="parallax"
    data-speed="-0.4"
    style="position:absolute; top:60px; left:-30px; font-family:var(--font-heading); font-size:clamp(110px,16vw,200px); font-weight:800; color:rgba(26,18,6,0.03); letter-spacing:-9px; line-height:0.8; pointer-events:none; white-space:nowrap;"
  >
    TEAM
  </div>
  <div style="max-width:1180px; margin:0 auto; position:relative;">
    <div
      data-fx="reveal"
      data-from="up"
      style="opacity:0; transform:translateY(48px) scale(0.95); filter:blur(8px); will-change:transform,opacity,filter; text-align:center; margin-bottom:60px;"
    >
      <p class="ds-grad-text-light" style="font-size:11px; font-weight:700; letter-spacing:3px; text-transform:uppercase; margin-bottom:14px;">ĐỘI NGŨ</p>
      <h2 style="font-family:var(--font-heading); font-size:clamp(30px,4vw,52px); font-weight:800; letter-spacing:-1.2px; line-height:1.12; color:#1a1206;">Con người đằng sau DryStack</h2>
    </div>
    <div
      data-fx="reveal"
      data-from="up"
      style="opacity:0; transform:translateY(48px) scale(0.95); filter:blur(8px); will-change:transform,opacity,filter;"
    >
      <TeamCarousel client:visible />
    </div>
  </div>
</section>
