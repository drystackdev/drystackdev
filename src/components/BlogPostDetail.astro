---
import { Image } from "astro:assets";
import Main from "../layout/main.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import JsonLd from "./JsonLd.astro";
import { getHomepage } from "../data/site";
import { htmlToPlainText } from "../lib/heading";
import type { BlogPost } from "../data/blog";

interface Props {
	post: BlogPost;
	related: BlogPost[];
	basePath: string;
	eyebrowLabel: string;
	backLabel: string;
}

const { post, related, basePath, eyebrowLabel, backLabel } = Astro.props;

const { brand } = await getHomepage() as any;
const siteName = htmlToPlainText(brand.name);

function formatDate(d: string) {
	return new Date(d).toLocaleDateString("vi-VN", { day: "2-digit", month: "2-digit", year: "numeric" });
}

const postUrl = new URL(`${basePath}/${post.slug}`, Astro.site).toString();

const articleSchema = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: post.title,
	description: post.excerpt,
	image: new URL(post.cover, Astro.site).toString(),
	datePublished: post.date,
	dateModified: post.updatedAt,
	mainEntityOfPage: { "@type": "WebPage", "@id": postUrl },
	author: { "@type": "Organization", name: siteName },
	publisher: { "@type": "Organization", name: siteName },
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{ "@type": "ListItem", position: 1, name: "Trang chủ", item: new URL("/", Astro.site).toString() },
		{ "@type": "ListItem", position: 2, name: eyebrowLabel, item: new URL(basePath, Astro.site).toString() },
		{ "@type": "ListItem", position: 3, name: post.title, item: postUrl },
	],
};
---

<Main title={`${post.title} | ${siteName}`} description={post.excerpt} keywords={post.keywords} image={post.cover} type="article">
	<Fragment slot="head">
		<meta property="article:published_time" content={new Date(post.date).toISOString()} />
		<meta property="article:modified_time" content={new Date(post.updatedAt).toISOString()} />
	</Fragment>
	<JsonLd schema={[articleSchema, breadcrumbSchema]} />
	<Header />

	<section class="post-hero section--dark" id="top">
		<div class="bg-layer">
			<div class="orb orb--gold" style="width:380px;height:380px;top:-10%;left:-8%;" data-parallax="0.12"></div>
		</div>
		<div class="container post-hero__inner">
			<a href={basePath} class="back-link reveal"><Icon name="arrow-left" size={16} /> {backLabel}</a>
			<p class="eyebrow reveal">{eyebrowLabel}</p>
			<h1 class="section-title reveal">{post.title}</h1>
			<div class="post-hero__meta reveal">
				<span><Icon name="calendar" size={14} /> {formatDate(post.date)}</span>
				{formatDate(post.updatedAt) !== formatDate(post.date) && (
					<span>Cập nhật: {formatDate(post.updatedAt)}</span>
				)}
			</div>
		</div>
	</section>

	<div class="container" >
		<div class="post-cover reveal">
			<Image src={post.cover} alt={post.title} width={1200} height={675} />
		</div>
	</div>

	<section class="post-body section--light">
		<div class="container post-layout">
			<div class="post-body__inner reveal" id="post-content" set:html={post.contentHtml} />
			<aside class="post-toc reveal reveal-right" id="post-toc-wrap" aria-label="Mục lục bài viết">
				<p class="post-toc__title">Tóm tắt</p>
				<nav class="post-toc__nav" id="post-toc-nav"></nav>
			</aside>
		</div>
	</section>

	<script>
		// Xây mục lục (Tóm tắt) từ các thẻ h2/h3/h4 bên trong nội dung bài viết,
		// vì post.contentHtml là HTML tự do (từ content editor) nên không có id
		// sẵn - phải gán id lúc chạy rồi mới build được các link neo (#id).
		const combiningMarks = new RegExp("[\\u0300-\\u036f]", "g");

		function slugify(text: string): string {
			return text
				.toLowerCase()
				.normalize("NFD")
				.replace(combiningMarks, "")
				.replace(/đ/g, "d")
				.replace(/[^a-z0-9\s-]/g, "")
				.trim()
				.replace(/\s+/g, "-")
				.replace(/-+/g, "-");
		}

		const content = document.getElementById("post-content");
		const tocWrap = document.getElementById("post-toc-wrap");
		const tocNav = document.getElementById("post-toc-nav");
		const headings = content
			? Array.from(content.querySelectorAll<HTMLElement>("h2, h3, h4"))
			: [];

		if (!content || !tocWrap || !tocNav || headings.length === 0) {
			tocWrap?.remove();
		} else {
			const usedIds = new Map<string, number>();
			const list = document.createElement("ul");
			const linkByHeadingId = new Map<string, HTMLAnchorElement>();

			headings.forEach((heading) => {
				if (!heading.id) {
					const base = slugify(heading.textContent || "") || "muc";
					const count = usedIds.get(base) ?? 0;
					usedIds.set(base, count + 1);
					heading.id = count === 0 ? base : `${base}-${count + 1}`;
				}

				const link = document.createElement("a");
				link.href = `#${heading.id}`;
				link.textContent = heading.textContent;
				link.className = `toc-level-${heading.tagName.toLowerCase()}`;

				const item = document.createElement("li");
				item.appendChild(link);
				list.appendChild(item);
				linkByHeadingId.set(heading.id, link);
			});

			tocNav.appendChild(list);

			// Scrollspy nhẹ: highlight mục đang đọc khi cuộn qua từng heading.
			// Nhiều heading có thể cùng giao cắt vùng quan sát một lúc (heading
			// gần nhau) - luôn chọn heading nằm trên cùng trong số đó, thay vì
			// tin vào thứ tự entries trả về (không đảm bảo theo vị trí).
			const intersecting = new Set<HTMLElement>();
			const headingObserver = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						const heading = entry.target as HTMLElement;
						if (entry.isIntersecting) intersecting.add(heading);
						else intersecting.delete(heading);
					}

					let active: HTMLElement | null = null;
					for (const heading of intersecting) {
						if (!active || heading.getBoundingClientRect().top < active.getBoundingClientRect().top) {
							active = heading;
						}
					}

					list
						.querySelectorAll("a.is-active")
						.forEach((el) => el.classList.remove("is-active"));
					if (active) linkByHeadingId.get(active.id)?.classList.add("is-active");
				},
				// IntersectionObserver chỉ nhận px/%, không nhận rem - 112px ứng
				// với 7rem (mốc scroll-margin-top/sticky top dùng ở CSS bên dưới).
				{ rootMargin: "-112px 0px -70% 0px", threshold: 0 },
			);
			headings.forEach((heading) => headingObserver.observe(heading));
		}
	</script>

	{related.length > 0 && (
		<section class="post-related section--light">
			<div class="container">
				<div class="post-related__head reveal">
					<h2 class="post-related__title">Bài viết liên quan</h2>
					<a href={basePath} class="btn btn-ghost post-related__all">Xem tất cả <Icon name="arrow-right" size={16} /></a>
				</div>
				<div class="post-related__grid" data-stagger>
					{related.map((p) => (
						<a href={`${basePath}/${p.slug}`} class="related-card reveal">
							<div class="related-card__cover">
								<Image src={p.cover} alt={p.title} loading="lazy" width={640} height={360} />
							</div>
							<div class="related-card__body">
								<h3>{p.title}</h3>
								<p class="related-card__excerpt">{p.excerpt}</p>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	<Footer />
</Main>

<style>
	.post-hero {
		padding-block: 9rem 5rem;
	}

	.post-hero__inner {
		position: relative;
		z-index: 1;
	}

	.back-link {
		display: flex;
		width: fit-content;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.85rem;
		color: var(--text-muted);
		margin-bottom: 1.5rem;
	}

	.back-link:hover {
		color: var(--primary-light);
	}

	.post-hero__meta {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		margin-top: 1.25rem;
		font-size: 0.85rem;
		color: var(--text-muted);
	}

	.post-hero__meta span {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
	}

	.post-body {
		padding-block: 5rem 6rem;
	}

	.post-layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 280px;
		gap: clamp(2rem, 4vw, 3.5rem);
		align-items: start;
	}

	.post-body__inner {
		grid-column: 1;
		grid-row: 1;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	/* reveal/reveal-right và position: sticky phải nằm trên CÙNG một phần tử.
	   Nếu sticky nằm ở phần tử con còn reveal (transform) nằm ở cha, transform
	   của cha sẽ tạo containing block mới và làm hỏng sticky của con - đây là
	   quirk CSS phổ biến (ancestor có transform/filter/will-change phá sticky). */
	.post-toc {
		grid-column: 2;
		grid-row: 1;
		position: sticky;
		/* top > 0 để không bị header (position: fixed) đè lên khi cuộn */
		top: 7rem;
		max-height: calc(100vh - 9rem);
		overflow-y: auto;
		background: var(--surface-light-card);
		border: 1px solid rgba(161, 127, 32, 0.15);
		border-radius: var(--radius-lg);
		padding: 1.5rem;
	}

	.post-toc__title {
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 0.85rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--secondary);
		margin-bottom: 1rem;
	}

	.post-toc__nav :global(ul) {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.post-toc__nav :global(a) {
		display: block;
		font-size: 0.88rem;
		line-height: 1.4;
		color: var(--text-dark-muted);
		word-break: break-word;
		transition: color 0.2s ease;
	}

	.post-toc__nav :global(a:hover) {
		color: var(--secondary);
	}

	.post-toc__nav :global(a.is-active) {
		color: var(--secondary);
		font-weight: 600;
	}

	.post-toc__nav :global(a.toc-level-h3) {
		padding-left: 1rem;
	}

	.post-toc__nav :global(a.toc-level-h4) {
		padding-left: 2rem;
	}

	/* Bù trừ cho header fixed khi cuộn tới neo #id từ mục lục. */
	.post-body__inner :global(h2),
	.post-body__inner :global(h3),
	.post-body__inner :global(h4) {
		scroll-margin-top: 7rem;
	}

	@media (max-width: 860px) {
		.post-layout {
			grid-template-columns: 1fr;
		}

		/* Trên mobile, mục lục hiện trên cùng của nội dung (không sticky). */
		.post-toc {
			grid-column: 1;
			grid-row: 1;
			position: static;
			max-height: none;
		}

		.post-body__inner {
			grid-column: 1;
			grid-row: 2;
		}
	}

	/* Markdoc wraps rendered output in an <article> - collapse it out of
	   the flow so the flex/gap layout above still applies to the <p> tags. */
	.post-body__inner :global(article) {
		display: contents;
	}

	/* :global() because this content is injected via set:html (rendered
	   from Markdoc), so Astro's scoped-style attribute never lands on it. */
	.post-body__inner :global(p) {
		font-size: 1.05rem;
		color: var(--text-dark-muted);
	}

	/* Aligned image from the "Ảnh" content component. .post-body__inner is a
	   flex column, so align-self on the <figure> itself is enough - no nested
	   wrapper needed. */
	.post-body__inner :global(.content-align) {
		margin: 0;
		max-width: 100%;
	}

	.post-body__inner :global(.content-align img) {
		display: block;
		max-width: 100%;
		height: auto;
		border-radius: var(--radius-lg);
	}

	.post-body__inner :global(.content-align--left) {
		align-self: flex-start;
	}

	.post-body__inner :global(.content-align--center) {
		align-self: center;
	}

	.post-body__inner :global(.content-align--right) {
		align-self: flex-end;
	}

	.post-cover {
		position: relative;
		margin-top: -3rem;
		aspect-ratio: 16 / 9;
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.5);
	}

	.post-cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.post-related {
		padding-block: 0 6rem;
	}

	.post-related__head {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
		margin-bottom: 1.75rem;
	}

	.post-related__title {
		font-family: var(--font-display);
		font-size: 1.5rem;
	}

	.post-related__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.25rem;
	}

	.related-card {
		display: block;
		background: var(--surface-light-card);
		border: 1px solid rgba(161, 127, 32, 0.15);
		border-radius: var(--radius-lg);
		overflow: hidden;
		transition: transform 0.3s ease, border-color 0.3s ease;
	}

	.related-card:hover {
		transform: translateY(-6px);
		border-color: rgba(161, 127, 32, 0.5);
	}

	.related-card__cover {
		aspect-ratio: 16 / 9;
		overflow: hidden;
	}

	.related-card__cover img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.related-card__body {
		padding: 1.1rem 1.25rem 1.4rem;
	}

	.related-card h3 {
		font-family: var(--font-display);
		font-size: 0.95rem;
		line-height: 1.4;
	}

	.related-card__excerpt {
		margin-top: 0.5rem;
		color: var(--text-dark-muted);
		font-size: 0.82rem;
		line-height: 1.5;
	}

	@media (max-width: 720px) {
		.post-related__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
