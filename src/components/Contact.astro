---
import ContactForm from "@/components/ContactForm"

const infos = [
  { icon: "solar:letter-bold-duotone", label: "Email", value: "info@drystack.dev", href: "mailto:info@drystack.dev" },
  { icon: "solar:phone-rounded-bold-duotone", label: "Zalo / Phone", value: "0866 442 504", href: "https://zalo.me/0866442504" },
  { icon: "solar:map-point-wave-bold-duotone", label: "Phạm vi", value: "Nhận dự án toàn quốc", href: null },
]
---

<section
  id="contact"
  style="scroll-margin-top:100px; position:relative; z-index:11; margin-top:-48px; border-radius:52px 52px 0 0; background:#faf5ec; color:#1a1206; padding:clamp(80px,10vw,130px) clamp(20px,5vw,40px) clamp(80px,10vw,120px); overflow:hidden; box-shadow:0 -24px 60px rgba(0,0,0,0.35);"
>
  <div style="max-width:1100px; margin:0 auto;">
    <div
      data-fx="reveal"
      data-from="up"
      style="opacity:0; transform:translateY(48px) scale(0.95); filter:blur(8px); will-change:transform,opacity,filter; text-align:center; margin-bottom:60px;"
    >
      <p class="ds-grad-text-light" style="font-size:11px; font-weight:700; letter-spacing:3px; text-transform:uppercase; margin-bottom:14px;">LIÊN HỆ</p>
      <h2 style="font-family:var(--font-heading); font-size:clamp(30px,4vw,52px); font-weight:800; letter-spacing:-1.2px; line-height:1.12; margin-bottom:16px; color:#1a1206;">Sẵn sàng bắt đầu dự án?</h2>
      <p style="font-size:17px; color:rgba(26,18,6,0.55); max-width:500px; margin:0 auto; line-height:1.7;">Điền form bên dưới hoặc nhắn tin trực tiếp. Chúng tôi phản hồi trong vòng 24h.</p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(290px,1fr)); gap:48px; align-items:start;">
      <div
        data-fx="reveal"
        data-from="right"
        style="opacity:0; transform:translateX(90px) scale(0.96); filter:blur(8px); will-change:transform,opacity,filter;"
      >
        <div style="display:flex; flex-direction:column; gap:22px; margin-bottom:36px;">
          {
            infos.map((info) => (
              info.href ? (
                <a href={info.href} target={info.href.startsWith("http") ? "_blank" : undefined} rel={info.href.startsWith("http") ? "noopener noreferrer" : undefined} class="info-row" style="display:flex; align-items:center; gap:16px; text-decoration:none;">
                  <div style="width:46px; height:46px; background:#fff; border-radius:13px; display:flex; align-items:center; justify-content:center; flex-shrink:0; box-shadow:0 6px 18px rgba(26,18,6,0.06); transition:box-shadow 0.2s;">
                    <iconify-icon icon={info.icon} style="font-size:24px; color:#ff8a3d;" />
                  </div>
                  <div>
                    <div style="font-size:12px; color:rgba(26,18,6,0.4); letter-spacing:1px; text-transform:uppercase; margin-bottom:3px;">{info.label}</div>
                    <div class="info-value" style="font-size:15px; color:#1a1206; font-weight:600;">{info.value}</div>
                  </div>
                </a>
              ) : (
                <div style="display:flex; align-items:center; gap:16px;">
                  <div style="width:46px; height:46px; background:#fff; border-radius:13px; display:flex; align-items:center; justify-content:center; flex-shrink:0; box-shadow:0 6px 18px rgba(26,18,6,0.06);">
                    <iconify-icon icon={info.icon} style="font-size:24px; color:#ff8a3d;" />
                  </div>
                  <div>
                    <div style="font-size:12px; color:rgba(26,18,6,0.4); letter-spacing:1px; text-transform:uppercase; margin-bottom:3px;">{info.label}</div>
                    <div style="font-size:15px; color:#1a1206; font-weight:600;">{info.value}</div>
                  </div>
                </div>
              )
            ))
          }
        </div>
        <div style="background:#fff; border-radius:16px; padding:22px 24px; box-shadow:0 10px 30px rgba(26,18,6,0.06);">
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px;">
            <div style="width:8px; height:8px; background:#ff8a3d; border-radius:50%; animation:blink 2s infinite;"></div>
            <span class="ds-grad-text-light" style="font-size:13px; font-weight:700; letter-spacing:0.5px;">PHẢN HỒI NHANH</span>
          </div>
          <p style="font-size:14px; color:rgba(26,18,6,0.6); line-height:1.6;">Thường phản hồi trong <strong style="color:#1a1206; font-weight:700;">dưới 2 tiếng</strong> trong giờ làm việc (8h–21h, T2–CN)</p>
        </div>
      </div>
      <div
        data-fx="reveal"
        data-from="left"
        style="opacity:0; transform:translateX(-90px) scale(0.96); filter:blur(8px); will-change:transform,opacity,filter;"
      >
        <ContactForm client:load />
      </div>
    </div>
  </div>
</section>

<style>
  .info-row { transition: opacity 0.2s; }
  .info-row:hover { opacity: 0.78; }
  .info-row:hover .info-value { color: #e8920c; }
</style>
