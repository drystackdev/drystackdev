DRYSTACK_GITHUB_CLIENT_ID=
DRYSTACK_GITHUB_CLIENT_SECRET=
DRYSTACK_SECRET=
PUBLIC_DRYSTACK_GITHUB_APP_SLUG=

# AI "Magic write" - xem docs/ai-providers.md
# anthropic | openai | google | openai-compatible
DRY_AI_PROVIDER=
DRY_AI_KEY=
# Bỏ trống để dùng model mặc định của provider.
# Bắt buộc khai khi DRY_AI_PROVIDER=openai-compatible.
DRY_AI_MODEL=
# Chỉ dùng cho openai-compatible (Groq, DeepSeek, OpenRouter, Ollama…).
DRY_AI_BASE_URL=

# cho demo public
PUBLIC_DEMO=
# Không cần tiền tố PUBLIC_ (xem packages/astro/src/index.ts's envPrefix).
# Bỏ trống = demo không có Magic write. Model dùng chung DRY_AI_MODEL ở trên.
DRYSTACK_AI_URL=

# Signs r2-mode login sessions + encrypts native-auth profiles - required for storage kind r2
DRYSTACK_SECRET=<openssl rand -hex 32>
