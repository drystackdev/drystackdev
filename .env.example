DRYSTACK_GITHUB_CLIENT_ID=
DRYSTACK_GITHUB_CLIENT_SECRET=
DRYSTACK_SECRET=
PUBLIC_DRYSTACK_GITHUB_APP_SLUG=

# AI "Magic write" - xem docs/ai-providers.md
# anthropic | openai | google | openai-compatible
DRY_AI_PROVIDER=
DRY_AI_KEY=
# Bỏ trống để dùng model mặc định của provider.
# Bắt buộc khai khi DRY_AI_PROVIDER=openai-compatible.
DRY_AI_MODEL=
# Chỉ dùng cho openai-compatible (Groq, DeepSeek, OpenRouter, Ollama…).
DRY_AI_BASE_URL=

# cho demo public
PUBLIC_DEMO=
# Không cần tiền tố PUBLIC_ (xem packages/astro/src/index.ts's envPrefix).
# Bỏ trống = demo không có Magic write. Model dùng chung DRY_AI_MODEL ở trên.
DRYSTACK_AI_URL=

# Signs r2-mode login sessions + encrypts native-auth profiles - required for storage kind r2
DRYSTACK_SECRET=<openssl rand -hex 32>

# Invite/forgot-password emails for storage kind r2 (see plan/user-managent.md
# mục 7). Two options, tried in this order - leave both blank to skip email
# sending entirely (user creation still works, the admin UI shows a copyable
# invite link instead):
#
# 1. Resend (resend.com) - works on the Workers Free plan. Needs a domain
#    verified in the Resend dashboard.
RESEND_API_KEY=
RESEND_FROM=
#
# 2. Cloudflare Email Sending - requires the Workers Paid plan. Must be an
#    address on a domain onboarded via
#    `bunx wrangler email sending enable yourdomain.com`.
DRYSTACK_EMAIL_FROM=
