      "default": "./dist/renderer.js"
    },
    "./path-utils": {
      "drystack-src": "./src/app/path-utils.ts",
      "default": "./dist/app/path-utils.js"
    },
    "./l10n": {
      "drystack-src": "./src/app/l10n/index.js",
      "default": "./dist/app/l10n/index.js"
    },
    "./redirects": {
      "drystack-src": "./src/app/redirects.ts",
      "default": "./dist/app/redirects.js"
    },
    "./edit-sync": {
      "drystack-src": "./src/app/edit-sync.ts",
      "default": "./dist/app/edit-sync.js"
    },
    "./media-library-bridge": {
      "drystack-src": "./src/app/media-library/bridge.ts",
      "default": "./dist/app/media-library/bridge.js"
    },
    "./change-preview": {
      "drystack-src": "./src/app/change-preview/ChangePreviewDialog.tsx",
      "default": "./dist/app/change-preview/ChangePreviewDialog.js"
    },
    "./media-host": {
      "drystack-src": "./src/app/media-library/VeiMediaHost.tsx",
      "default": "./dist/app/media-library/VeiMediaHost.js"
    },
    "./file-manager-host": {
      "drystack-src": "./src/app/file-manager/FileManagerHost.tsx",
      "default": "./dist/app/file-manager/FileManagerHost.js"
    },
    "./field-editor": {
      "drystack-src": "./src/app/field-editor.tsx",
      "default": "./dist/app/field-editor.js"
    },
    "./auth": {
      "drystack-src": "./src/app/auth.ts",
      "default": "./dist/app/auth.js"
    },
    "./required-files": {
      "drystack-src": "./src/app/required-files.ts",
      "default": "./dist/app/required-files.js"
    },
    "./build-status": {
      "drystack-src": "./src/app/build-status.ts",
      "default": "./dist/app/build-status.js"
    },
    "./build-status-protocol": {
      "drystack-src": "./src/app/build-status-protocol.ts",
      "default": "./dist/app/build-status-protocol.js"
    },
    "./brand-store": {
      "drystack-src": "./src/app/brand-store.ts",
      "default": "./dist/app/brand-store.js"
    },
    "./brand-label": {
      "drystack-src": "./src/app/brand-label.ts",
      "default": "./dist/app/brand-label.js"
    },
    "./deploy-merge": {
      "drystack-src": "./src/app/deploy/merge3.ts",
      "default": "./dist/app/deploy/merge3.js"
    },
    "./deploy-merge-base": {
      "drystack-src": "./src/app/deploy/merge-base.ts",
      "default": "./dist/app/deploy/merge-base.js"
    },
    "./deploy-cloudflare-status": {
      "drystack-src": "./src/app/deploy/CloudflareStatus.tsx",
      "default": "./dist/app/deploy/CloudflareStatus.js"
    },
    "./yaml": {
      "drystack-src": "./src/yaml.ts",
      "default": "./dist/yaml.js"
    },
    "./reader": {
      "drystack-src": "./src/reader/index.ts",
      "default": "./dist/reader/index.js"
    },
    "./reader/github": {
      "drystack-src": "./src/reader/github.ts",
      "default": "./dist/reader/github.js"
    },
    "./content-components": {
      "drystack-src": "./src/content-components.ts",
      "default": "./dist/content-components.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "l10n": "tsx scripts/l10n.ts",
    "setup": "tsx scripts/build-prism.ts",
    "build": "bun run setup && node scripts/build.mjs",
    "dev": "astro dev"
  },
  "dependencies": {
    "@babel/runtime": "^7.18.3",
    "@braintree/sanitize-url": "^6.0.2",
    "@emotion/weak-memoize": "^0.3.0",
    "@floating-ui/react": "^0.24.0",
    "@internationalized/string": "^3.2.6",
    "@keystar/ui": "^0.7.21",
    "@markdoc/markdoc": "^0.4.0",
    "@react-aria/focus": "^3.20.2",
    "@react-aria/i18n": "^3.12.8",
    "@react-aria/interactions": "^3.25.0",
    "@react-aria/label": "^3.7.17",
    "@react-aria/overlays": "^3.27.0",
    "@react-aria/selection": "^3.24.0",
    "@react-aria/utils": "^3.28.2",
    "@react-aria/visually-hidden": "^3.8.22",
    "@react-stately/collections": "^3.12.3",
    "@react-stately/list": "^3.12.1",
    "@react-stately/overlays": "^3.6.15",
    "@react-stately/utils": "^3.10.6",
    "@react-types/shared": "^3.29.0",
    "@sindresorhus/slugify": "^1.1.2",
    "@ts-gql/tag": "^0.7.3",
    "@types/react": "^19.0.8",
    "@urql/core": "^5.0.4",
    "@urql/exchange-auth": "^2.2.0",
    "@urql/exchange-graphcache": "^7.1.2",
    "@urql/exchange-persisted": "^4.3.0",
    "cookie": "^1.0.0",
    "emery": "^1.4.1",
    "escape-string-regexp": "^4.0.0",
    "fast-deep-equal": "^3.1.3",
    "graphql": "^16.6.0",
    "idb-keyval": "^6.2.1",
    "ignore": "^5.2.4",
    "is-hotkey": "^0.2.0",
    "js-yaml": "^4.1.0",
    "lru-cache": "^10.2.0",
    "match-sorter": "^6.3.1",
    "mdast-util-from-markdown": "^2.0.0",
    "mdast-util-gfm-autolink-literal": "^2.0.0",
    "mdast-util-gfm-strikethrough": "^2.0.0",
    "mdast-util-gfm-table": "^2.0.0",
    "mdast-util-mdx": "^3.0.0",
    "mdast-util-to-markdown": "^2.1.0",
    "micromark-extension-gfm-autolink-literal": "^2.0.0",
    "micromark-extension-gfm-strikethrough": "^2.0.0",
    "micromark-extension-gfm-table": "^2.0.0",
    "micromark-extension-mdxjs": "^3.0.0",
    "minimatch": "^9.0.3",
    "node-diff3": "^3.2.1",
    "prosemirror-commands": "^1.5.1",
    "prosemirror-history": "^1.3.0",
    "prosemirror-keymap": "^1.2.1",
    "prosemirror-model": "^1.19.0",
    "prosemirror-state": "^1.4.2",
    "prosemirror-tables": "^1.3.4",
    "prosemirror-transform": "^1.7.1",
    "prosemirror-view": "^1.30.2",
    "scroll-into-view-if-needed": "^3.0.3",
    "slate": "^0.91.4",
    "slate-history": "^0.86.0",
    "slate-react": "^0.91.9",
    "superstruct": "^1.0.4",
    "unist-util-visit": "^5.0.0",
    "urql": "^4.1.0",
    "y-prosemirror": "^1.2.2",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.11"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@iconify-json/solar": "^1.2.5",
    "@iconify/utils": "^3.1.4",
    "@internationalized/string-compiler": "^3.2.6",
    "@jest/expect": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "@testing-library/user-event": "^14.6.1",
    "@ts-gql/compiler": "^0.16.7",
    "@ts-gql/eslint-plugin": "^0.9.1",
    "@ts-gql/next": "^17.0.1",
    "@types/is-hotkey": "^0.1.7",
    "@types/js-yaml": "^4.0.5",
    "@types/mdast": "^4.0.3",
