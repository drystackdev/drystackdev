    "signal-exit": "^3.0.7",
    "slate-hyperscript": "^0.77.0",
    "tsx": "^4.8.2",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "ts-gql": {
    "schema": "./github.graphql",
    "mode": "no-transform",
    "addTypename": false,
    "scalars": {
      "GitObjectID": "string"
    }
  },
  "imports": {
    "#react-cache-in-react-server": {
      "react-server": {
        "drystack-src": "./src/reader/react-server-cache.ts",
        "default": "./dist/reader/react-server-cache.js"
      },
      "default": {
        "drystack-src": "./src/reader/noop-cache.ts",
        "default": "./dist/reader/noop-cache.js"
      }
    },
    "#sha1": {
      "node": {
        "drystack-src": "./src/sha1/node.ts",
        "default": "./dist/sha1/node.js"
      },
      "default": {
        "drystack-src": "./src/sha1/webcrypto.ts",
        "default": "./dist/sha1/webcrypto.js"
      }
    },
    "#webcrypto": {
      "node": {
        "drystack-src": "./src/api/webcrypto/node.ts",
        "default": "./dist/api/webcrypto/node.js"
      },
      "default": {
        "drystack-src": "./src/api/webcrypto/default.ts",
        "default": "./dist/api/webcrypto/default.js"
      }
    },
    "#api-handler": {
      "node": {
        "drystack-src": "./src/api/api-node.ts",
        "default": "./dist/api/api-node.js"
      },
      "default": {
        "drystack-src": "./src/api/api-noop.ts",
        "default": "./dist/api/api-noop.js"
      }
    },
    "#ui": {
      "node": {
        "drystack-src": "./src/app/ui-empty.tsx",
        "default": "./dist/app/ui-empty.js"
      },
      "worker": {
        "drystack-src": "./src/app/ui-empty.tsx",
        "default": "./dist/app/ui-empty.js"
      },
      "react-server": {
        "drystack-src": "./src/app/ui-empty.tsx",
        "default": "./dist/app/ui-empty.js"
      },
      "default": {
        "drystack-src": "./src/app/ui.tsx",
        "default": "./dist/app/ui.js"
      }
    },
    "#field-ui/*": {
      "node": {
        "drystack-src": "./src/form/fields/empty-field-ui.tsx",
        "default": "./dist/form/fields/empty-field-ui.js"
      },
      "worker": {
        "drystack-src": "./src/form/fields/empty-field-ui.tsx",
        "default": "./dist/form/fields/empty-field-ui.js"
      },
      "react-server": {
        "drystack-src": "./src/form/fields/empty-field-ui.tsx",
        "default": "./dist/form/fields/empty-field-ui.js"
      },
      "default": {
        "drystack-src": "./src/form/fields/*/ui.tsx",
        "default": "./dist/form/fields/*/ui.js"
      }
    },
    "#icons/*": {
      "drystack-src": "./src/app/icons/*.tsx",
      "default": "./dist/app/icons/*.js"
    },
    "#component-block-primitives": {
      "node": {
        "drystack-src": "./src/component-blocks/primitives/blank-for-react-server.tsx",
        "default": "./dist/component-blocks/primitives/blank-for-react-server.js"
      },
      "worker": {
        "drystack-src": "./src/component-blocks/primitives/blank-for-react-server.tsx",
        "default": "./dist/component-blocks/primitives/blank-for-react-server.js"
      },
      "react-server": {
        "drystack-src": "./src/component-blocks/primitives/blank-for-react-server.tsx",
        "default": "./dist/component-blocks/primitives/blank-for-react-server.js"
      },
      "default": {
        "drystack-src": "./src/component-blocks/primitives/index.tsx",
        "default": "./dist/component-blocks/primitives/index.js"
      }
    },
    "#markdoc": {
      "drystack-src": "./src/markdoc.js",
      "default": "./dist/markdoc.js"
    },
    "#base64": {
      "drystack-src": "./src/base64.ts",
      "default": "./dist/base64.js"
    },
    "#react-compiler-runtime": {
      "react-server": {
        "drystack-src": "./src/react-compiler-runtime-react-server.ts",
        "default": "./dist/react-compiler-runtime-react-server.js"
      },
      "default": {
        "drystack-src": "./src/react-compiler-runtime.ts",
        "default": "./dist/react-compiler-runtime.js"
      }
    }
  }
}
