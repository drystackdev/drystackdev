    "@types/signal-exit": "^3.0.1",
    "@vitest/pretty-format": "^3.0.5",
    "eslint": "^8.18.0",
    "happy-dom": "^20.10.6",
    "jest-diff": "^29.0.1",
    "mkdist": "^2.4.1",
