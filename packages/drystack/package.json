{
  "name": "@drystack/core",
  "version": "0.0.1",
  "description": "Core engine for drystack, a git-backed CMS for Astro inspired by Keystatic.",
  "license": "MIT",
  "homepage": "https://github.com/drystackdev/drystackdev",
  "repository": {
    "type": "git",
    "url": "https://github.com/drystackdev/drystackdev",
    "directory": "packages/drystack"
  },
  "type": "module",
  "keywords": [
    "drystack",
    "cms",
    "keystatic",
    "astro",
    "cloudflare",
    "git-cms",
    "headless-cms",
    "content-management"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "drystack-src": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./ui": {
      "drystack-src": "./src/ui.tsx",
      "default": "./dist/ui.js"
    },
    "./api/utils": {
      "drystack-src": "./src/api/utils.ts",
      "default": "./dist/api/utils.js"
    },
    "./api/generic": {
      "drystack-src": "./src/api/generic.ts",
      "default": "./dist/api/generic.js"
    },
    "./api/ai": {
      "drystack-src": "./src/api/ai/index.ts",
      "default": "./dist/api/ai/index.js"
    },
    "./api/ai/schema": {
      "drystack-src": "./src/api/ai/schema-to-yaml.ts",
      "default": "./dist/api/ai/schema-to-yaml.js"
    },
    "./api/ai/prompt": {
      "drystack-src": "./src/api/ai/prompt.ts",
      "default": "./dist/api/ai/prompt.js"
    },
    "./api/encryption": {
      "drystack-src": "./src/api/encryption.tsx",
      "default": "./dist/api/encryption.js"
    },
    "./renderer": {
