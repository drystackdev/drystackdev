---
// eslint-disable-next-line import/no-unresolved
import config from 'virtual:drystack-config';
// eslint-disable-next-line import/no-unresolved
import basePath from 'virtual:drystack-path';

export const prerender = false;

// Same reasoning as drystack-login.astro: only r2-mode storage has native
// email/password auth (see plan/user-managent.md). This page is reachable
// with NO session cookie at all, by design - its authority is the one-time
// token in the URL (`?token=`), issued by `POST users` (invite) or
// `POST forgot-password` (reset), both in user-management.ts. Deliberately
// plain HTML/vanilla JS like drystack-login.astro, not a React island - this
// has to load fast and work before any admin-app JS, same as login.
if (config?.storage?.kind !== 'r2') {
  return Astro.redirect('/');
}

const token = Astro.url.searchParams.get('token') ?? '';

const vi = (config?.locale ?? '').toLowerCase().startsWith('vi');
const t = vi
  ? {
      title: 'Đặt mật khẩu',
      newPassword: 'Mật khẩu mới',
      confirmPassword: 'Xác nhận mật khẩu',
      showPassword: 'Hiện mật khẩu',
      hidePassword: 'Ẩn mật khẩu',
      submit: 'Đặt mật khẩu',
      loading: 'Đang xử lý…',
      errorMissingToken: 'Thiếu token, vui lòng dùng đúng link trong email.',
      errorInvalidToken:
        'Link đã hết hạn hoặc không hợp lệ. Hãy yêu cầu gửi lại.',
      errorPasswordShort: 'Mật khẩu phải có ít nhất 8 ký tự.',
      errorPasswordMismatch: 'Hai mật khẩu không khớp.',
      errorGeneric: 'Có lỗi xảy ra, thử lại sau.',
      successRedirecting: 'Đã đặt mật khẩu, đang chuyển tới trang đăng nhập…',
    }
  : {
      title: 'Set password',
      newPassword: 'New password',
      confirmPassword: 'Confirm password',
      showPassword: 'Show password',
      hidePassword: 'Hide password',
      submit: 'Set password',
      loading: 'Working…',
      errorMissingToken: 'Missing token - use the link from your email.',
      errorInvalidToken: 'This link expired or is invalid. Ask for a new one.',
      errorPasswordShort: 'Password must be at least 8 characters.',
      errorPasswordMismatch: "Passwords don't match.",
      errorGeneric: 'Something went wrong, try again later.',
      successRedirecting: 'Password set, redirecting to sign in…',
    };

const apiBase = `/api/${basePath}`;
---

<!doctype html>
<html lang={vi ? 'vi' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{t.title}</title>
  </head>
  <body>
    <main class="card">
      <img class="logo" src="/favicon.svg" alt="" />
      <h1>{t.title}</h1>
      {
        !token && (
          <p id="error" role="alert">
            {t.errorMissingToken}
          </p>
        )
      }
      {
        token && (
          <form id="password-form">
            <label>
              <span>{t.newPassword}</span>
              <div class="password-field">
                <input
                  name="password"
                  type="password"
                  required
                  minlength="8"
                  autocomplete="new-password"
                  autofocus
                />
                <button
                  type="button"
                  class="password-toggle"
                  aria-label={t.showPassword}
                  data-show-label={t.showPassword}
                  data-hide-label={t.hidePassword}
                />
              </div>
            </label>
            <label>
              <span>{t.confirmPassword}</span>
              <div class="password-field">
                <input
                  name="confirmPassword"
                  type="password"
                  required
                  minlength="8"
                  autocomplete="new-password"
                />
                <button
                  type="button"
                  class="password-toggle"
                  aria-label={t.showPassword}
                  data-show-label={t.showPassword}
                  data-hide-label={t.hidePassword}
                />
              </div>
            </label>
            <p id="error" role="alert" hidden />
            <button type="submit" id="submit">
              {t.submit}
            </button>
          </form>
        )
      }
    </main>

    <script
      is:inline
      define:vars={{
        apiBase,
        token,
        strings: t,
        loginTarget: `/login`,
      }}
    >
      const form = document.getElementById('password-form');
      if (form) {
        const errorEl = document.getElementById('error');
        const submitEl = document.getElementById('submit');

        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          errorEl.hidden = true;
          const data = new FormData(form);
          const password = data.get('password');
          const confirmPassword = data.get('confirmPassword');
          if (password !== confirmPassword) {
            errorEl.textContent = strings.errorPasswordMismatch;
            errorEl.hidden = false;
            return;
          }
          submitEl.disabled = true;
          const original = submitEl.textContent;
          submitEl.textContent = strings.loading;
          try {
            const res = await fetch(`${apiBase}/password-setting`, {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ token, password }),
            });
            if (res.ok) {
              submitEl.textContent = strings.successRedirecting;
              location.replace(loginTarget);
              return;
            }
            const body = await res.json().catch(() => null);
            errorEl.textContent =
              body?.error === 'password-too-short'
                ? strings.errorPasswordShort
                : body?.error === 'invalid-or-expired-token'
                  ? strings.errorInvalidToken
                  : strings.errorGeneric;
            errorEl.hidden = false;
          } catch {
            errorEl.textContent = strings.errorGeneric;
            errorEl.hidden = false;
          } finally {
            submitEl.disabled = false;
            submitEl.textContent = original;
          }
        });
      }
    </script>

    <script is:inline>
      // Show/hide toggle, shared across every password field on the page
      // (new + confirm) - clicking either one reveals/hides both, matching
      // the "sync across password inputs" UX the plan asks for (the React
      // admin's zustand-backed SyncedPasswordField does the same for pages
      // inside the admin app; this page is plain vanilla JS, so this is the
      // equivalent for it).
      const eyeIcon =
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>';
      const eyeOffIcon =
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.9 4.24A10.94 10.94 0 0 1 12 4c6.5 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.53 13.53 0 0 0 2 11s3.5 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><path d="M2 2l20 20"/><path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/></svg>';

      const toggles = [...document.querySelectorAll('.password-toggle')];
      let visible = false;
      const applyVisibility = () => {
        for (const button of toggles) {
          const input = button.previousElementSibling;
          input.type = visible ? 'text' : 'password';
          button.innerHTML = visible ? eyeOffIcon : eyeIcon;
          button.setAttribute(
            'aria-label',
            visible ? button.dataset.hideLabel : button.dataset.showLabel
          );
        }
      };
      toggles.forEach((button) => {
        button.addEventListener('click', () => {
          visible = !visible;
          applyVisibility();
        });
      });
      applyVisibility();
    </script>

    <style is:global>
      :root {
        color-scheme: light dark;
        --bg: #f6f7f9;
        --card: #ffffff;
        --text: #1a1d21;
        --muted: #5c636b;
        --border: #d7dbe0;
        --accent: #3b6ef5;
        --accent-text: #ffffff;
        --error: #c62f2f;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #15171a;
          --card: #1e2126;
          --text: #e8eaed;
          --muted: #9aa1a9;
          --border: #34383f;
          --accent: #5c85f7;
          --error: #ef6a6a;
        }
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100dvh;
        display: grid;
        place-items: center;
        background: var(--bg);
        color: var(--text);
        font-family:
          system-ui,
          -apple-system,
          'Segoe UI',
          Roboto,
          sans-serif;
      }
      .card {
        width: min(92vw, 22rem);
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 2rem;
      }
      .logo {
        display: block;
        width: 40px;
        height: 40px;
        margin: 0 auto 1rem;
      }
      h1 {
        margin: 0 0 1.25rem;
        font-size: 1.25rem;
        text-align: center;
      }
      form {
        display: grid;
        gap: 1rem;
      }
      label {
        display: grid;
        gap: 0.35rem;
        font-size: 0.85rem;
        color: var(--muted);
      }
      input {
        font: inherit;
        color: inherit;
        background: transparent;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.55rem 0.7rem;
        width: 100%;
      }
      input:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 1px;
        border-color: transparent;
      }
      .password-field {
        position: relative;
        display: flex;
      }
      .password-field input {
        padding-inline-end: 2.5rem;
      }
      .password-toggle {
        position: absolute;
        inset-inline-end: 0;
        top: 0;
        bottom: 0;
        width: 2.5rem;
        display: grid;
        place-items: center;
        background: transparent;
        border: 0;
        border-radius: 0 8px 8px 0;
        padding: 0;
        color: var(--muted);
        cursor: pointer;
      }
      .password-toggle:hover {
        color: var(--text);
      }
      .password-toggle svg {
        width: 18px;
        height: 18px;
      }
      #error {
        margin: 0;
        font-size: 0.85rem;
        color: var(--error);
      }
      button[type='submit'] {
        font: inherit;
        font-weight: 600;
        border: 0;
        border-radius: 8px;
        padding: 0.6rem;
        background: var(--accent);
        color: var(--accent-text);
        cursor: pointer;
      }
      button:disabled {
        opacity: 0.6;
        cursor: default;
      }
    </style>
  </body>
</html>
