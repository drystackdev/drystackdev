---
import { Drystack } from './drystack-page.js';
import { getNativeSession } from '../src/native-session.ts';
// eslint-disable-next-line import/no-unresolved
import config from 'virtual:drystack-config';

export const prerender = false;

// r2-mode deployments are public, so the admin shell itself sits behind the
// native login (see plan/auth.md): no valid session cookie means a redirect
// out to /login before any admin JS is served. Demo builds need no such
// check - they're read-only and fully static.
if (config?.storage?.kind === 'r2') {
  const session = await getNativeSession(Astro.request);
  if (!session) {
    const from = Astro.url.pathname + Astro.url.search;
    return Astro.redirect(`/login?from=${encodeURIComponent(from)}`);
  }
}
---

<Drystack client:only="react" />
