{
  "name": "@drystack/astro",
  "version": "0.0.1",
  "description": "Astro integration for drystack, a git-backed CMS for Astro inspired by Keystatic.",
  "license": "MIT",
  "homepage": "https://github.com/drystackdev/drystackdev",
  "repository": {
    "type": "git",
    "url": "https://github.com/drystackdev/drystackdev",
    "directory": "packages/astro"
  },
  "type": "module",
  "exports": {
    "./ui": {
      "drystack-src": "./src/ui.tsx",
      "default": "./dist/ui.js"
    },
    "./api": {
      "drystack-src": "./src/api.tsx",
      "default": "./dist/api.js"
    },
    "./dry": {
      "drystack-src": "./src/dry.ts",
      "default": "./dist/dry.js"
    },
    "./reader": {
      "drystack-src": "./src/reader.ts",
      "default": "./dist/reader.js"
    },
    "./editor": {
      "drystack-src": "./src/editor/index.tsx",
      "default": "./dist/editor/index.js"
    },
    "./worker": {
      "drystack-src": "./src/worker/index.ts",
      "default": "./dist/worker/index.js"
    },
    ".": {
      "drystack-src": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./internal/drystack-api.js": "./internal/drystack-api.js",
    "./internal/drystack-astro-page.astro": "./internal/drystack-astro-page.astro"
  },
  "keywords": [
    "astro-integration",
    "astro",
    "astro-component",
    "drystack",
    "cms",
    "keystatic",
    "cloudflare",
    "cloudflare-workers",
    "git-cms",
    "headless-cms",
    "content-management"
  ],
  "files": [
    "dist",
    "internal"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.worker.json"
  },
  "dependencies": {
    "@babel/runtime": "^7.18.3",
    "@keystar/ui": "^0.7.21",
    "@react-aria/i18n": "^3.12.8",
    "@types/react": "^19.0.8",
    "js-yaml": "^4.1.0",
    "set-cookie-parser": "^2.5.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "@drystack/core": "workspace:^",
    "@types/js-yaml": "^4.0.5",
    "@types/set-cookie-parser": "^2.4.2",
    "astro": "^7.0.6",
    "mkdist": "^2.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.0.0",
    "@types/node": "^26.1.0"
  },
  "peerDependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@drystack/core": ">=0.0.1 <1.0.0",
    "astro": "2 || 3 || 4 || 5 || 6 || 7",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
  },
  "peerDependenciesMeta": {
    "@astrojs/cloudflare": {
      "optional": true
    }
  }
}
